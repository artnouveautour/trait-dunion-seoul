---
const { pathname } = Astro.url;
const isPath = (p: string) =>
  pathname === p || pathname === p + '/' || pathname.startsWith(p + '/');
const onAbout = isPath('/about');
const onServices = isPath('/services');
const onInterpretation = isPath('/interpretation');
const onVip = isPath('/vip-guiding');
const onVersailles = isPath('/versailles');
const onFaq = isPath('/faq');
const onContact = isPath('/contact');
const onAnyService = onServices || onInterpretation || onVip || onVersailles;
---
<header class="topbar" id="topbar">
  <a href="/" class="brand" style="display:flex; align-items:center; gap:0.8rem; text-decoration:none; color:var(--ink);">
    <svg width="34" height="34" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0">
      <circle cx="20" cy="20" r="18" fill="none" stroke="#1a2238" stroke-width="0.8" opacity="0.4"/>
      <line x1="8" y1="20" x2="32" y2="20" stroke="#b08d57" stroke-width="1.2"/>
      <circle cx="13" cy="20" r="2" fill="#1a2238"/>
      <circle cx="27" cy="20" r="2" fill="#4a5a4d"/>
      <text x="20" y="13" font-family="EB Garamond, serif" font-size="6" font-style="italic" fill="#1a2238" text-anchor="middle" opacity="0.7">tu</text>
    </svg>
    <div>
      Trait d'Union <em>Séoul</em>
      <span class="brand-sub">Paris · Séoul · 트레 뒤니옹</span>
    </div>
  </a>
  <nav>
    <a href="/about" aria-current={onAbout ? 'page' : null}>소개</a>
    <span class="nav-dropdown">
      <a href="/services" aria-current={onAnyService ? 'page' : null}>서비스</a>
      <div class="nav-dropdown-menu">
        <a href="/services" aria-current={onServices ? 'page' : null}>전체 보기</a>
        <a href="/interpretation" aria-current={onInterpretation ? 'page' : null}>비즈니스 통역</a>
        <a href="/vip-guiding" aria-current={onVip ? 'page' : null}>VIP 맞춤 가이딩</a>
        <a href="/versailles" aria-current={onVersailles ? 'page' : null}>베르사유</a>
      </div>
    </span>
    <a href="/vip-guiding" aria-current={onVip ? 'page' : null}>VIP 맞춤 가이딩</a>
    <a href="/versailles" aria-current={onVersailles ? 'page' : null}>베르사유</a>
    <a href="/faq" aria-current={onFaq ? 'page' : null}>FAQ</a>
    <a href="/contact" class="cta-mini" aria-current={onContact ? 'page' : null}>견적 요청</a>
  </nav>
</header>
