---
export const prerender = false;
import Site from '../layouts/Site.astro';
import { getTour, SERVICE_LABELS } from '../lib/reviews';

const url = new URL(Astro.request.url);
const token = url.searchParams.get('token') || '';
const env = (Astro.locals as any).runtime?.env as ENV | undefined;

let tour: Awaited<ReturnType<typeof getTour>> = null;
let error: string | null = null;
let serviceLabel = '';

if (!token) {
  error = '후기 작성은 투어 후 운영자가 보내드린 링크로만 진행됩니다.';
} else if (!env?.REVIEWS_KV) {
  error = '서비스 설정이 완료되지 않았습니다 (KV 미바인딩).';
} else {
  tour = await getTour(env.REVIEWS_KV, token);
  if (!tour) {
    error = '유효하지 않은 후기 작성 링크입니다.';
  } else if (tour.used) {
    error = '이미 후기가 제출된 링크입니다. 수정이 필요하면 contact@traitdunionseoul.com 으로 알려주세요.';
  } else {
    serviceLabel = tour.serviceLabel || SERVICE_LABELS[tour.service] || tour.service;
  }
}
---
<Site
  title="후기 작성 — Trait d'Union Séoul"
  description="투어를 마치신 손님께서 후기를 남기실 수 있는 페이지. 운영자가 보내드린 일회용 링크로 접속해주세요."
>

<main class="legal-content" style="padding-top:8rem;">
  <div class="legal-eyebrow">Témoignage</div>
  <h1>후기 <span class="it">작성</span></h1>

  {error && (
    <p class="legal-meta" style="margin-bottom:2rem;">
      {error}<br/>
      문의 — <a href="mailto:contact@traitdunionseoul.com">contact@traitdunionseoul.com</a>
    </p>
  )}

  {tour && !error && (
    <>
      <p class="legal-meta">
        {serviceLabel} · {tour.tourDate} · 손님 — {tour.customerName}
      </p>

      <form id="reviewForm" class="form" style="margin-top:1rem;">
        <input type="hidden" name="token" value={tour.token} />
        <div class="form-row">
          <label>표시될 이름 (성함)</label>
          <input type="text" name="name" required maxlength="60" value={tour.customerName} />
        </div>
        <div class="form-row">
          <label>별점</label>
          <select name="rating" required>
            <option value="">선택해주세요</option>
            <option value="5">★★★★★ (5)</option>
            <option value="4">★★★★☆ (4)</option>
            <option value="3">★★★☆☆ (3)</option>
            <option value="2">★★☆☆☆ (2)</option>
            <option value="1">★☆☆☆☆ (1)</option>
          </select>
        </div>
        <div class="form-row">
          <label>후기 내용 (최소 10자)</label>
          <textarea name="text" required rows="6" minlength="10" maxlength="2000" placeholder="투어에서 느끼신 점을 자유롭게 적어주세요."></textarea>
        </div>
        <button type="submit" class="form-submit">후기 제출하기</button>
        <p class="form-note">제출하신 후기는 운영자 검토 후 사이트에 게재됩니다 (영업일 기준 1–3일).</p>
        <div class="form-success" id="reviewSuccess">
          후기가 제출되었습니다.<br>
          검토 후 사이트의 후기 섹션에 게재됩니다. 감사합니다.
        </div>
        <div class="form-success" id="reviewError" style="background:#a44; display:none;"></div>
      </form>
    </>
  )}
</main>

<script is:inline>
  (function () {
    var form = document.getElementById('reviewForm');
    if (!form) return;
    var success = document.getElementById('reviewSuccess');
    var errorBox = document.getElementById('reviewError');
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      errorBox.style.display = 'none';
      var data = Object.fromEntries(new FormData(form));
      try {
        var res = await fetch('/api/reviews/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        var json = await res.json();
        if (res.ok && json.ok) {
          success.classList.add('active');
          form.querySelectorAll('input, select, textarea, button').forEach(function (el) { el.disabled = true; });
        } else {
          errorBox.textContent = json.error || ('제출 중 오류 (' + res.status + ')');
          errorBox.style.display = 'block';
        }
      } catch (err) {
        errorBox.textContent = '네트워크 오류로 제출되지 않았습니다.';
        errorBox.style.display = 'block';
      }
    });
  })();
</script>

</Site>
