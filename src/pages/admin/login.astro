---
export const prerender = false;
import Site from '../../layouts/Site.astro';
---
<Site
  title="어드민 로그인 — Trait d'Union Séoul"
  description="운영자 전용 로그인 페이지"
>

<main class="legal-content" style="padding-top:8rem; max-width:520px;">
  <div class="legal-eyebrow">Admin</div>
  <h1>로그인</h1>
  <p class="legal-meta">운영자 이메일을 입력하시면 로그인 링크를 보내드립니다. 메일함의 링크를 30분 안에 클릭해주세요.</p>

  <form id="loginForm" class="form" style="margin-top:1rem;">
    <div class="form-row">
      <label>이메일</label>
      <input type="email" name="email" required autocomplete="email" />
    </div>
    <button type="submit" class="form-submit">로그인 링크 받기</button>
    <p class="form-note">입력하신 이메일이 등록된 운영자 이메일과 일치하는 경우에만 발송됩니다.</p>
    <div class="form-success" id="loginSuccess">
      입력하신 이메일이 등록된 운영자 이메일이라면 로그인 링크를 보내드렸습니다.<br>
      메일함을 확인해주세요.
    </div>
  </form>
</main>

<script is:inline>
(function () {
  var form = document.getElementById('loginForm');
  if (!form) return;
  var success = document.getElementById('loginSuccess');
  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    var data = Object.fromEntries(new FormData(form));
    try {
      await fetch('/api/auth/magic-send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
    } catch (err) { /* 보안: 결과 무관하게 같은 메시지 */ }
    success.classList.add('active');
    form.querySelectorAll('input, button').forEach(function (el) { el.disabled = true; });
  });
})();
</script>

</Site>
